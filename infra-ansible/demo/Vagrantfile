Vagrant.configure("2") do |config|

  # Rocky Linux 9 = RHEL-family, uses yum, has systemd — matches our Ansible roles
  config.vm.box = "generic/rocky9"
  config.vm.hostname = "dev-app-01"

  # Same IP as inventory/dev.yml → ansible_host: 192.168.10.10
  config.vm.network "private_network", ip: "192.168.10.10"

  config.vm.provider "virtualbox" do |vb|
    vb.name   = "dev-app-01"
    vb.memory = 1024
    vb.cpus   = 1
  end

  # Provisioning script — runs ONCE when you first do "vagrant up"
  # Creates the "deploy" user and installs our public key so Ansible can SSH in
  config.vm.provision "shell" do |s|
    # Read the public key generated by generate_key.sh
    pub_key = File.read(File.join(File.dirname(__FILE__), "deploy_key.pub")).strip
    s.inline = <<-SHELL
      # 1. Create deploy user (skip if already exists)
      id deploy &>/dev/null || useradd -m -s /bin/bash deploy

      # 2. Set up .ssh directory
      mkdir -p /home/deploy/.ssh
      chmod 700 /home/deploy/.ssh

      # 3. Install the public key
      echo "#{pub_key}" >> /home/deploy/.ssh/authorized_keys
      chmod 600 /home/deploy/.ssh/authorized_keys
      chown -R deploy:deploy /home/deploy/.ssh

      # 4. Allow deploy user to sudo without password (Ansible needs this for become: true)
      echo "deploy ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/deploy
      chmod 440 /etc/sudoers.d/deploy

      echo "==> deploy user is ready"
    SHELL
  end

end